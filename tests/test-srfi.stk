                     (string-index->cursor ABC 0)))
(test "string-cursor>?" #t (string-cursor>? (string-index->cursor ABC 2)
                     (string-index->cursor ABC 1)))
(test "string-cursor>?" #t (not (string-cursor>? (string-index->cursor ABC 2)
                          (string-index->cursor ABC 2))))
(test "string-cursor>?" #t (not (string-cursor>? (string-index->cursor ABC 2)
                          (string-index->cursor ABC 3))))
(test "string-cursor>?" #t (string-cursor>? (string-index->cursor ABC 3)
                     (string-index->cursor ABC 0)))
(test "string-cursor>?" #t (string-cursor>? (string-index->cursor ABC 3)
                     (string-index->cursor ABC 1)))
(test "string-cursor>?" #t (string-cursor>? (string-index->cursor ABC 3)
                     (string-index->cursor ABC 2)))
(test "string-cursor>?" #t (not (string-cursor>? (string-index->cursor ABC 3)
                          (string-index->cursor ABC 3))))

(test "string-cursor<=?" #t (string-cursor<=? (string-index->cursor ABC 0)
                     (string-index->cursor ABC 0)))

(test "string-cursor<=?" #t (string-cursor<=? (string-index->cursor ABC 0)
                      (string-index->cursor ABC 1)))

(test "string-cursor<=?" #t (string-cursor<=? (string-index->cursor ABC 0)
                      (string-index->cursor ABC 2)))

(test "string-cursor<=?" #t (string-cursor<=? (string-index->cursor ABC 0)
                      (string-index->cursor ABC 3)))

(test "string-cursor<=?" #t (not (string-cursor<=? (string-index->cursor ABC 1)
                           (string-index->cursor ABC 0))))

(test "string-cursor<=?" #t (string-cursor<=? (string-index->cursor ABC 1)
                      (string-index->cursor ABC 1)))

(test "string-cursor<=?" #t (string-cursor<=? (string-index->cursor ABC 1)
                      (string-index->cursor ABC 2)))

(test "string-cursor<=?" #t (string-cursor<=? (string-index->cursor ABC 1)
                      (string-index->cursor ABC 3)))

(test "string-cursor<=?" #t (not (string-cursor<=? (string-index->cursor ABC 2)
                           (string-index->cursor ABC 0))))

(test "string-cursor<=?" #t (not (string-cursor<=? (string-index->cursor ABC 2)
                           (string-index->cursor ABC 1))))

(test "string-cursor<=?" #t (string-cursor<=? (string-index->cursor ABC 2)
                      (string-index->cursor ABC 2)))

(test "string-cursor<=?" #t (string-cursor<=? (string-index->cursor ABC 2)
                      (string-index->cursor ABC 3)))

(test "string-cursor<=?" #t (not (string-cursor<=? (string-index->cursor ABC 3)
                           (string-index->cursor ABC 0))))

(test "string-cursor<=?" #t (not (string-cursor<=? (string-index->cursor ABC 3)
                           (string-index->cursor ABC 1))))

(test "string-cursor<=?" #t (not (string-cursor<=? (string-index->cursor ABC 3)
                           (string-index->cursor ABC 2))))

(test "string-cursor<=?" #t (string-cursor<=? (string-index->cursor ABC 3)
                      (string-index->cursor ABC 3)))


(test "string-cursor>=?" #t (string-cursor>=? (string-index->cursor ABC 0)
                      (string-index->cursor ABC 0)))

(test "string-cursor>=?" #t (not (string-cursor>=? (string-index->cursor ABC 0)
                           (string-index->cursor ABC 1))))

(test "string-cursor>=?" #t (not (string-cursor>=? (string-index->cursor ABC 0)
                           (string-index->cursor ABC 2))))

(test "string-cursor>=?" #t (not (string-cursor>=? (string-index->cursor ABC 0)
                           (string-index->cursor ABC 3))))

(test "string-cursor>=?" #t (string-cursor>=? (string-index->cursor ABC 1)
                      (string-index->cursor ABC 0)))

(test "string-cursor>=?" #t (string-cursor>=? (string-index->cursor ABC 1)
                      (string-index->cursor ABC 1)))

(test "string-cursor>=?" #t (not (string-cursor>=? (string-index->cursor ABC 1)
                           (string-index->cursor ABC 2))))

(test "string-cursor>=?" #t (not (string-cursor>=? (string-index->cursor ABC 1)
                           (string-index->cursor ABC 3))))

(test "string-cursor>=?" #t (string-cursor>=? (string-index->cursor ABC 2)
                      (string-index->cursor ABC 0)))

(test "string-cursor>=?" #t (string-cursor>=? (string-index->cursor ABC 2)
                      (string-index->cursor ABC 1)))

(test "string-cursor>=?" #t (string-cursor>=? (string-index->cursor ABC 2)
                      (string-index->cursor ABC 2)))

(test "string-cursor>=?" #t (not (string-cursor>=? (string-index->cursor ABC 2)
                           (string-index->cursor ABC 3))))

(test "string-cursor>=?" #t (string-cursor>=? (string-index->cursor ABC 3)
                      (string-index->cursor ABC 0)))

(test "string-cursor>=?" #t (string-cursor>=? (string-index->cursor ABC 3)
                      (string-index->cursor ABC 1)))

(test "string-cursor>=?" #t (string-cursor>=? (string-index->cursor ABC 3)
                      (string-index->cursor ABC 2)))

(test "string-cursor>=?" #t (string-cursor>=? (string-index->cursor ABC 3)
                      (string-index->cursor ABC 3)))


(test "string-cursor-diff" #t (= 0 (string-cursor-diff ""
                             (string-index->cursor ABC 0)
                             (string-index->cursor ABC 0))))

(test "string-cursor-diff" #t (= 3 (string-cursor-diff ABC
                             (string-index->cursor ABC 0)
                             (string-index->cursor ABC 3))))

(test "string-cursor->index" #t (= 0 (string-cursor->index "" (string-index->cursor "" 0))))
(test "string-cursor->index" #t (= 3 (string-cursor->index ABC (string-index->cursor ABC 3))))
(test "string-index->cursor" #t (= 0 (string-index->cursor "" (string-index->cursor "" 0))))
(test "string-index->cursor" #t (= 3 (string-index->cursor ABC (string-index->cursor ABC 3))))

;;; Predicates

(test "string-null"  #t (string-null? ""))
(test "string-null"  #f (string-null? "abc"))
(test "string-every" #t (string-every (lambda (c) (if (char? c) c #f)) ""))
(test "string-every" #\c (string-every (lambda (c) (if (char? c) c #f)) "abc"))
(test "string-every" #f (string-every (lambda (c) (if (char>? c #\b) c #f)) "abc"))
(test "string-every" #\c (string-every (lambda (c) (if (char>? c #\b) c #f)) "abc" 2))
(test "string-every" #t (string-every (lambda (c) (if (char>? c #\b) c #f)) "abc" 1 1))

(test "string-any" #t (eqv? #f (string-any (lambda (c) (if (char? c) c #f)) "")))
(test "string-any" #t (eqv? #\a (string-any (lambda (c) (if (char? c) c #f)) "abc")))
(test "string-any" #t (eqv? #\c (string-any (lambda (c) (if (char>? c #\b) c #f)) "abc")))
(test "string-any" #t (eqv? #\c (string-any (lambda (c) (if (char>? c #\b) c #f)) "abc" 2)))
(test "string-any" #t (eqv? #f (string-any (lambda (c) (if (char>? c #\b) c #f)) "abc" 0 2)))

;;; Constructors

(test "string-tabulate" #t (equal? ""
            (string-tabulate (lambda (i)
                               (integer->char (+ i (char->integer #\a))))
                             0)))

(test "string-tabulate" #t (equal? "abc"
            (string-tabulate (lambda (i)
                               (integer->char (+ i (char->integer #\a))))
                             3)))

(test "string-unfold" #t (equal? "abc"
            (let ((p (open-input-string "abc")))
              (string-unfold eof-object?
                             values
                             (lambda (x) (read-char p))
                             (read-char p)))))

(test "string-unfold" #t (equal? ""  (string-unfold null? car cdr '())))
(test "string-unfold" #t (equal? "abc" (string-unfold null? car cdr (string->list "abc"))))
(test "string-unfold" #t (equal? "def" (string-unfold null? car cdr '() "def")))
(test "string-unfold" #t (equal? "defabcG"
            (string-unfold null?
                           car
                           cdr
                           (string->list "abc")
                           "def"
                           (lambda (x) (and (null? x) "G")))))
(test "string-unfold-right" #t (equal? ""  (string-unfold-right null? car cdr '())))
(test "string-unfold-right" #t (equal? "cba" (string-unfold-right null? car cdr (string->list "abc"))))
(test "string-unfold-right" #t (equal? "def" (string-unfold-right null? car cdr '() "def")))
(test "string-unfold-right" #t (equal? "Gcbadef"
            (string-unfold-right null?
                                 car
                                 cdr
                                 (string->list "abc")
                                 "def"
                                 (lambda (x) (and (null? x) "G")))))

;;; Conversion

(test "string->list/cursors" #t (equal? '() (string->list/cursors "")))
(test "string->list/cursors" #t (equal? '() (string->list/cursors ""  0)))
(test "string->list/cursors" #t (equal? '() (string->list/cursors ""  0 0)))
(test "string->list/cursors" #t (equal? '(#\a #\b #\c) (string->list/cursors "abc")))
(test "string->list/cursors" #t (equal? '() (string->list/cursors "abc"  3)))
(test "string->list/cursors" #t (equal? '(#\b #\c) (string->list/cursors "abc"  1 3)))
(test "string->list/cursors" #t (equal? '(#\b #\c)
            (string->list/cursors "abc"
                                  (string-index->cursor "abc" 1)
                                  (string-index->cursor "abc" 3))))
(test "string->vector/cursors" #t (equal? '#() (string->vector/cursors "")))
(test "string->vector/cursors" #t (equal? '#() (string->vector/cursors ""  0)))
(test "string->vector/cursors" #t (equal? '#() (string->vector/cursors ""  0 0)))
(test "string->vector/cursors" #t (equal? '#(#\a #\b #\c) (string->vector/cursors "abc")))
(test "string->vector/cursors" #t (equal? '#() (string->vector/cursors "abc"  3)))
(test "string->vector/cursors" #t (equal? '#(#\b #\c) (string->vector/cursors "abc"  1 3)))
(test "string->vector/cursors" #t (equal? '#(#\b #\c)
            (string->vector/cursors "abc"
                                  (string-index->cursor "abc" 1)
                                  (string-index->cursor "abc" 3))))
(test "reverse-list->string" #t (equal? "" (reverse-list->string '())))
(test "reverse-list->string" #t (equal? "cba" (reverse-list->string '(#\a #\b #\c))))

(test "string-join" #t (equal? "" (string-join '())))
(test "string-join" #t (equal? "ab cd  e f "
            (string-join '("" "ab" "cd" "" "e" "f" ""))))

(test "string-join" #t (equal? "" (string-join '() "")))

(test "string-join" #t (equal? "abcdef"
            (string-join '("" "ab" "cd" "" "e" "f" "") "")))

(test "string-join" #t (equal? "" (string-join '() "xyz")))

(test "string-join" #t (equal? "xyzabxyzcdxyzxyzexyzfxyz"
            (string-join '("" "ab" "cd" "" "e" "f" "") "xyz")))

(test "string-join" #t (equal? "" (string-join '() "" 'infix)))

(test "string-join" #t (equal? "abcdef"
            (string-join '("" "ab" "cd" "" "e" "f" "") "" 'infix)))

(test "string-join" #t (equal? "" (string-join '() "xyz" 'infix)))

(test "string-join" #t (equal? "xyzabxyzcdxyzxyzexyzfxyz"
            (string-join '("" "ab" "cd" "" "e" "f" "") "xyz" 'infix)))

(test "string-join" #t (equal? 'horror
            (guard (exn (#t 'horror))
             (string-join '() "" 'strict-infix))))

(test "string-join" #t (equal? "abcdef"
            (string-join '("" "ab" "cd" "" "e" "f" "") "" 'strict-infix)))

(test "string-join" #t (equal? 'wham
            (guard (exn (else 'wham))
             (string-join '() "xyz" 'strict-infix))))
(test "string-join" #t (equal? "xyzabxyzcdxyzxyzexyzfxyz"
            (string-join '("" "ab" "cd" "" "e" "f" "") "xyz" 'strict-infix)))
(test "string-join" #t (equal? "" (string-join '() ""  'suffix)))
(test "string-join" #t (equal? "abcdef"
            (string-join '("" "ab" "cd" "" "e" "f" "") "" 'suffix)))
(test "string-join" #t (equal? "" (string-join '() "xyz"  'suffix)))
(test "string-join" #t (equal? "xyzabxyzcdxyzxyzexyzfxyzxyz"
            (string-join '("" "ab" "cd" "" "e" "f" "") "xyz" 'suffix)))
(test "string-join" #t (equal? "" (string-join '() ""  'prefix)))
(test "string-join" #t (equal? "abcdef"
            (string-join '("" "ab" "cd" "" "e" "f" "") "" 'prefix)))
(test "string-join" #t (equal? "" (string-join '() "xyz"  'prefix)))
(test "string-join" #t (equal? "xyzxyzabxyzcdxyzxyzexyzfxyz"
            (string-join '("" "ab" "cd" "" "e" "f" "") "xyz" 'prefix)))

;;; Selection

(test "string-ref/cursor" #t (char=? #\a (string-ref/cursor "abc"  0)))
(test "string-ref/cursor" #t (char=? #\c (string-ref/cursor "abc"  2)))
(test "string-ref/cursor" #t (char=? #\a (string-ref/cursor "abc" (string-index->cursor "abc"  0))))
(test "string-ref/cursor" #t (char=? #\c (string-ref/cursor "abc" (string-index->cursor "abc"  2))))
(test "substring/cursors" #t (string=? "" (substring/cursors ""  0 0)))
(test "substring/cursors" #t (string=? "" (substring/cursors "abc"  0 0)))
(test "substring/cursors" #t (string=? "" (substring/cursors "abc"  3 3)))
(test "substring/cursors" #t (string=? ABC (substring/cursors ABC 0 3)))
(test "substring/cursors" #t (string=? ABC
              (substring/cursors ABC
                                 (string-index->cursor "abc" 0)
                                 (string-index->cursor "abc" 3))))
(test "substring/cursors" #t (string=? "b" (substring/cursors "abc"  1 2)))
(test "string-copy/cursors" #t (string=? "" (string-copy/cursors "")))
(test "string-copy/cursors" #t (string=? "abc"  (string-copy/cursors "abc")))
(test "string-copy/cursors" #t (string=? "" (string-copy/cursors "abc"  3)))
(test "string-copy/cursors" #t (string=? "c" (string-copy/cursors "abc"  2)))
(test "string-copy/cursors" #t (string=? "abc" (string-copy/cursors "abc"  0)))
(test "string-copy/cursors" #t (string=? "b" (string-copy/cursors "abc"  1 2)))
(test "string-copy/cursors" #t (string=? "" (string-copy/cursors ""  0 0)))
(test "string-copy/cursors" #t (string=? "" (string-copy/cursors "abc"  0 0)))
(test "string-copy/cursors" #t (string=? "" (string-copy/cursors "abc"  3 3)))
(test "string-copy/cursors" #t (string=? "abc" (string-copy/cursors "abc"  0 3)))
(test "string-copy/cursors" #t (string=? "b" (string-copy/cursors "abc"  1 2)))
(test "string-copy/cursors" #t (string=? (substring ABC 1 2)
              (string-copy/cursors ABC
                                   (string-index->cursor "abc" 1)
                                   (string-index->cursor "abc" 2))))
(test "string-take" #t (string=? "" (string-take ""  0)))
(test "string-take" #t (string=? "" (string-take "abcdef"  0)))
(test "string-take" #t (string=? "ab" (string-take "abcdef"  2)))
(test "string-drop" #t (string=? "" (string-drop ""  0)))
(test "string-drop" #t (string=? "abcdef" (string-drop "abcdef"  0)))
(test "string-drop" #t (string=? "cdef" (string-drop "abcdef"  2)))
(test "string-take-right" #t (string=? "" (string-take-right ""  0)))
(test "string-take-right" #t (string=? "" (string-take-right "abcdef"  0)))
(test "string-take-right" #t (string=? "ef" (string-take-right "abcdef"  2)))
(test "string-drop-right" #t (string=? "" (string-drop-right ""  0)))
(test "string-drop-right" #t (string=? "abcdef" (string-drop-right "abcdef"  0)))
(test "string-drop-right" #t (string=? "abcd" (string-drop-right "abcdef"  2)))
(test "string-pad" #t (string=? "" (string-pad ""  0)))
(test "string-pad" #t (string=? "     " (string-pad ""  5)))
(test "string-pad" #t (string=? "  325" (string-pad "325"  5)))
(test "string-pad" #t (string=? "71325" (string-pad "71325"  5)))
(test "string-pad" #t (string=? "71325" (string-pad "8871325"  5)))
(test "string-pad" #t (string=? "" (string-pad ""  0 #\*)))
(test "string-pad" #t (string=? "*****" (string-pad ""  5 #\*)))
(test "string-pad" #t (string=? "**325" (string-pad "325"  5 #\*)))
(test "string-pad" #t (string=? "71325" (string-pad "71325"  5 #\*)))
(test "string-pad" #t (string=? "71325" (string-pad "8871325"  5 #\*)))
(test "string-pad" #t (string=? "" (string-pad ""  0 #\* 0)))
(test "string-pad" #t (string=? "*****" (string-pad ""  5 #\* 0)))
(test "string-pad" #t (string=? "**325" (string-pad "325"  5 #\* 0)))
(test "string-pad" #t (string=? "71325" (string-pad "71325"  5 #\* 0)))
(test "string-pad" #t (string=? "71325" (string-pad "8871325"  5 #\* 0)))
(test "string-pad" #t (string=? "***25" (string-pad "325"  5 #\* 1)))
(test "string-pad" #t (string=? "*1325" (string-pad "71325"  5 #\* 1)))
(test "string-pad" #t (string=? "71325" (string-pad "8871325"  5 #\* 1)))
(test "string-pad" #t (string=? "" (string-pad ""  0 #\* 0 0)))
(test "string-pad" #t (string=? "*****" (string-pad ""  5 #\* 0 0)))
(test "string-pad" #t (string=? "**325" (string-pad "325"  5 #\* 0 3)))
(test "string-pad" #t (string=? "**713" (string-pad "71325"  5 #\* 0 3)))
(test "string-pad" #t (string=? "**887" (string-pad "8871325"  5 #\* 0 3)))
(test "string-pad" #t (string=? "***25" (string-pad "325"  5 #\* 1 3)))
(test "string-pad" #t (string=? "**132" (string-pad "71325"  5 #\* 1 4)))
(test "string-pad" #t (string=? "*8713" (string-pad "8871325"  5 #\* 1 5)))
(test "string-pad-right" #t (string=? "" (string-pad-right ""  0)))
(test "string-pad-right" #t (string=? "     " (string-pad-right ""  5)))
(test "string-pad-right" #t (string=? "325  " (string-pad-right "325"  5)))
(test "string-pad-right" #t (string=? "71325" (string-pad-right "71325"  5)))
(test "string-pad-right" #t (string=? "88713" (string-pad-right "8871325"  5)))
(test "string-pad-right" #t (string=? "" (string-pad-right ""  0 #\*)))
(test "string-pad-right" #t (string=? "*****" (string-pad-right ""  5 #\*)))
(test "string-pad-right" #t (string=? "325**" (string-pad-right "325"  5 #\*)))
(test "string-pad-right" #t (string=? "71325" (string-pad-right "71325"  5 #\*)))
(test "string-pad-right" #t (string=? "88713" (string-pad-right "8871325"  5 #\*)))
(test "string-pad-right" #t (string=? "" (string-pad-right ""  0 #\* 0)))
(test "string-pad-right" #t (string=? "*****" (string-pad-right ""  5 #\* 0)))
(test "string-pad-right" #t (string=? "325**" (string-pad-right "325"  5 #\* 0)))
(test "string-pad-right" #t (string=? "71325" (string-pad-right "71325"  5 #\* 0)))
(test "string-pad-right" #t (string=? "88713" (string-pad-right "8871325"  5 #\* 0)))
(test "string-pad-right" #t (string=? "25***" (string-pad-right "325"  5 #\* 1)))
(test "string-pad-right" #t (string=? "1325*" (string-pad-right "71325"  5 #\* 1)))
(test "string-pad-right" #t (string=? "87132" (string-pad-right "8871325"  5 #\* 1)))
(test "string-pad-right" #t (string=? "" (string-pad-right ""  0 #\* 0 0)))
(test "string-pad-right" #t (string=? "*****" (string-pad-right ""  5 #\* 0 0)))
(test "string-pad-right" #t (string=? "325**" (string-pad-right "325"  5 #\* 0 3)))
(test "string-pad-right" #t (string=? "713**" (string-pad-right "71325"  5 #\* 0 3)))
(test "string-pad-right" #t (string=? "887**" (string-pad-right "8871325"  5 #\* 0 3)))
(test "string-pad-right" #t (string=? "25***" (string-pad-right "325"  5 #\* 1 3)))
(test "string-pad-right" #t (string=? "132**" (string-pad-right "71325"  5 #\* 1 4)))
(test "string-pad-right" #t (string=? "8713*" (string-pad-right "8871325"  5 #\* 1 5)))

(test "string-trim" #t (string=? ""  (string-trim "")))
(test "string-trim" #t (string=? "a  b  c  " (string-trim "  a  b  c  ")))
(test "string-trim" #t (string=? "" (string-trim "" char-whitespace?)))
(test "string-trim" #t (string=? "a  b  c  " (string-trim "  a  b  c  " char-whitespace?)))
(test "string-trim" #t (string=? "" (string-trim "  a  b  c  " char?)))
(test "string-trim" #t (string=? "" (string-trim "" char-whitespace? 0)))
(test "string-trim" #t (string=? "a  b  c  " (string-trim "  a  b  c  " char-whitespace? 0)))
(test "string-trim" #t (string=? "" (string-trim "  a  b  c  " char? 0)))
(test "string-trim" #t (string=? "b  c  " (string-trim "  a  b  c  " char-whitespace? 3)))
(test "string-trim" #t (string=? "" (string-trim "  a  b  c  " char? 3)))
(test "string-trim" #t (string=? "" (string-trim "  a  b  c  " char? 0 11)))
(test "string-trim" #t (string=? "b  c  " (string-trim "  a  b  c  " char-whitespace? 3 11)))
(test "string-trim" #t (string=? "" (string-trim "  a  b  c  " char? 3 11)))
(test "string-trim" #t (string=? "" (string-trim "  a  b  c  " char? 0 8)))
(test "string-trim" #t (string=? "b  " (string-trim "  a  b  c  " char-whitespace? 3 8)))
(test "string-trim" #t (string=? "" (string-trim "  a  b  c  " char? 3 8)))

(test "string-trim-right" #t (string=? ""  (string-trim-right "")))
(test "string-trim-right" #t (string=? "  a  b  c" (string-trim-right "  a  b  c  ")))
(test "string-trim-right" #t (string=? "" (string-trim-right "" char-whitespace?)))
(test "string-trim-right" #t (string=? "  a  b  c" (string-trim-right "  a  b  c  " char-whitespace?)))
(test "string-trim-right" #t (string=? "" (string-trim-right "  a  b  c  " char?)))
(test "string-trim-right" #t (string=? "" (string-trim-right "" char-whitespace? 0)))
(test "string-trim-right" #t (string=? "  a  b  c" (string-trim-right "  a  b  c  " char-whitespace? 0)))
(test "string-trim-right" #t (string=? "" (string-trim-right "  a  b  c  " char? 0)))
(test "string-trim-right" #t (string=? "  b  c" (string-trim-right "  a  b  c  " char-whitespace? 3)))
(test "string-trim-right" #t (string=? "" (string-trim-right "  a  b  c  " char? 3)))
(test "string-trim-right" #t (string=? "" (string-trim-right "  a  b  c  " char? 0 11)))
(test "string-trim-right" #t (string=? "  b  c" (string-trim-right "  a  b  c  " char-whitespace? 3 11)))
(test "string-trim-right" #t (string=? "" (string-trim-right "  a  b  c  " char? 3 11)))
(test "string-trim-right" #t (string=? "" (string-trim-right "  a  b  c  " char? 0 8)))
(test "string-trim-right" #t (string=? "  b" (string-trim-right "  a  b  c  " char-whitespace? 3 8)))
(test "string-trim-right" #t (string=? "" (string-trim-right "  a  b  c  " char? 3 8)))

(test "string-trim-both" #t (string=? "" #t (string-trim-both "")))
(test "string-trim-both" #t (string=? "a  b  c" (string-trim-both "  a  b  c  ")))
(test "string-trim-both" #t (string=? "" (string-trim-both ""  char-whitespace?)))
(test "string-trim-both" #t (string=? "a  b  c" (string-trim-both "  a  b  c  "  char-whitespace?)))
(test "string-trim-both" #t (string=? "" (string-trim-both "  a  b  c  "  char?)))
(test "string-trim-both" #t (string=? "" (string-trim-both ""  char-whitespace? 0)))
(test "string-trim-both" #t (string=? "a  b  c" (string-trim-both "  a  b  c  "  char-whitespace? 0)))
(test "string-trim-both" #t (string=? "" (string-trim-both "  a  b  c  "  char? 0)))
(test "string-trim-both" #t (string=? "b  c" (string-trim-both "  a  b  c  "  char-whitespace? 3)))
(test "string-trim-both" #t (string=? "" (string-trim-both "  a  b  c  "  char? 3)))
(test "string-trim-both" #t (string=? "" (string-trim-both "  a  b  c  "  char? 0 11)))
(test "string-trim-both" #t (string=? "b  c" (string-trim-both "  a  b  c  "  char-whitespace? 3 11)))
(test "string-trim-both" #t (string=? "" (string-trim-both "  a  b  c  "  char? 3 11)))
(test "string-trim-both" #t (string=? "" (string-trim-both "  a  b  c  "  char? 0 8)))
(test "string-trim-both" #t (string=? "b" (string-trim-both "  a  b  c  "  char-whitespace? 3 8)))
(test "string-trim-both" #t (string=? "" (string-trim-both "  a  b  c  "  char? 3 8)))

(test "string-prefix-length" #t (= 0 (string-prefix-length ""  "")))
