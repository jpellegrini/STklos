(test "string-cursor>=?" #t (string-cursor>=? 3 3))

(test "string-cursor=?" #t (string-cursor=? (string-index->cursor ABC 0)
                     (string-index->cursor ABC 0)))
(test "string-cursor=?" #t (not (string-cursor=? (string-index->cursor ABC 0)
                          (string-index->cursor ABC 1))))
