       (string-cursor->index "abcdef"
                             (string-skip-right "abcdef"
                                                (lambda (c) (char<=? c #\d))))))

(test "string-skip-right" #t (= 0
       (string-cursor->index "abcdef"
                             (string-skip-right "abcdef" char?))))


