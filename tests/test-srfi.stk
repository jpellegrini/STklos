;;; Searching

(test "string-index" #t (= 0
       (string-cursor->index ""
                             (string-index "" char?))))
(test "string-index" #t (= 0
       (string-cursor->index "abcdef"
                             (string-index "abcdef" char?))))
(test "string-index" #t (= 4
       (string-cursor->index "abcdef"
                             (string-index "abcdef"
                                           (lambda (c) (char>? c #\d))))))
(test "string-index" #t (= 6
       (string-cursor->index "abcdef"
                             (string-index "abcdef" char-whitespace?))))
(test "string-index-right" #t (= 0
       (string-cursor->index "abcdef"
                             (string-index-right "" char?))))
(test "string-index-right" #t (= 6
       (string-cursor->index "abcdef"
                             (string-index-right "abcdef" char?))))
(test "string-index-right" #t (= 6
       (string-cursor->index "abcdef"
                             (string-index-right "abcdef"
                                                 (lambda (c) (char>? c #\d))))))
(test "string-index-right" #t (= 0
       (string-cursor->index "abcdef"
                             (string-index-right "abcdef" char-whitespace?))))
(test "string-skip" #t (= 0
       (string-cursor->index ""  (string-skip "" string?))))
(test "string-skip" #t (= 0
       (string-cursor->index "abcdef"
                             (string-skip "abcdef" string?))))

(test "string-skip" #t (= 4
       (string-cursor->index "abcdef"
                             (string-skip "abcdef"
                                          (lambda (c) (char<=? c #\d))))))

(test "string-skip" #t (= 6
       (string-cursor->index "abcdef"
                             (string-skip "abcdef" char?))))

(test "string-skip-right" #t (= 0
       (string-cursor->index ""  (string-skip-right "" string?))))

