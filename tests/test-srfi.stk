(test "string-cursor<?" #t (not (string-cursor<? 3 1)))
(test "string-cursor<?" #t (not (string-cursor<? 3 2)))
(test "string-cursor<?" #t (not (string-cursor<? 3 3)))


(test "string-cursor>?" #t (not (string-cursor>? 0 0)))
(test "string-cursor>?" #t (not (string-cursor>? 0 1)))
(test "string-cursor>?" #t (not (string-cursor>? 0 2)))
(test "string-cursor>?" #t (not (string-cursor>? 0 3)))
